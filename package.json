{
  "name": "codeveal",
  "displayName": "Codeveal",
  "description": "Right-click any module folder → AI-powered architecture mindmap & feature graph in your editor.",
  "version": "0.5.0",
  "publisher": "Franki",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/NikFranki/glimpse"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeveal.analyzeModule",
        "title": "Codeveal: Analyze This Module"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "codeveal.analyzeModule",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "codeveal.analyzeModule",
          "when": "!explorerResourceIsFolder && resourceExtname =~ /\\.(ts|tsx|vue|js)$/",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Codeveal",
      "properties": {
        "codeveal.companyScopes": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["@scfe", "@spx", "@ssc", "@sc/", "ssc-", "sc-cli", "react-pro-components"],
          "description": "Package name prefixes treated as internal company deps (shown separately in the mindmap)"
        },
        "codeveal.aiProvider": {
          "type": "string",
          "enum": ["auto", "claude", "codex"],
          "enumDescriptions": [
            "Auto-detect: prefer claude, fallback to codex",
            "Force claude CLI (requires Claude Code installed)",
            "Force codex CLI (requires OpenAI Codex installed)"
          ],
          "default": "auto",
          "description": "Which AI CLI to use (auto detects automatically)"
        },
        "codeveal.aiTimeout": {
          "type": "number",
          "default": 360,
          "minimum": 30,
          "description": "AI CLI call timeout in seconds. The subprocess is killed and an error is shown when exceeded."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "vscode:prepublish": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@vue/component-compiler-utils": "^3.3.0",
    "ts-morph": "^21.0.0",
    "vue-template-compiler": "^2.7.16"
  }
}
